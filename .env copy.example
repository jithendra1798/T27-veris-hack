# === GAUNTLET — Environment Variables ===
# Copy to .env and fill in real values. Never commit .env.

# ============================================================================
# REQUIRED FOR COMPETITION DEMO
# ============================================================================

# Baseten (LLM inference for attack generation + verdict evaluation)
# Get key from: https://app.baseten.co/settings/api-keys
BASETEN_API_KEY=your_baseten_api_key_here

# OpenAI (Veris-style scenario generation)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# OPTIONAL (Fallbacks work without these)
# ============================================================================

# You.com (exploit research citations — fallback OWASP citations work without this)
# Get key from: https://api.you.com
YOU_API_KEY=your_you_api_key_here

# Baseten Orpheus TTS (voice rendering — deterministic text responses work without this)
BASETEN_ORPHEUS_MODEL_ID=
ORPHEUS_ENVIRONMENT=production
ORPHEUS_VOICE=tara

# ============================================================================
# ADVANCED CONFIGURATION (defaults work for demo)
# ============================================================================

# Optional LLM override for BE2 target responses
VOICE_LLM_API_KEY=
VOICE_LLM_BASE_URL=
VOICE_LLM_MODEL=gpt-4.1-mini
VOICE_LLM_TEMPERATURE=0.2
VOICE_RESPONSE_STRATEGY=deterministic
VOICE_PLAYBACK_MODE=voicerun
ATTACKER_VOICE=lyric
TARGET_VOICE=nova
TARGET_RESPONSE_URL=http://127.0.0.1:8000/internal/target/respond
VOICE_STATIC_BASE_URL=http://127.0.0.1:8000
EVALUATOR_RESPONSE_URL=http://localhost:8000/evaluator/response

# Legacy (not used — OpenAI replaces this)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Service URLs (defaults for local dev)
BE2_TARGET_URL=http://localhost:8001/internal/target/respond
BE2_TARGET_MODE_URL=http://localhost:8001/target/mode
