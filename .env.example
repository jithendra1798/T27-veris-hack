# === GAUNTLET — Environment Variables ===
# Copy to .env and fill in real values. Never commit .env.

# Baseten (LLM inference + TTS)
BASETEN_API_KEY=your_baseten_api_key_here

# You.com (exploit research citations)
YOU_API_KEY=your_you_api_key_here

# Veris (scenario generation — uses Anthropic internally)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Service URLs (defaults for local dev)
BE2_ATTACKER_URL=http://localhost:8001/attacker/attack
BE2_TARGET_MODE_URL=http://localhost:8001/target/mode
